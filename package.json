{
  "name": "ip2d",
  "version": "2.4.9",
  "license": "MIT",
  "author": "0xflotus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xflotus/ip2d.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "terser index.js --compress --mangle --output dist/index.js",
    "format": "oxfmt",
    "lint": "oxlint *.{js,mjs}",
    "eslint": "eslint *.js",
    "prelint": "npm run format",
    "pretest": "npm run build",
    "test": "NODE_V8_COVERAGE=coverage node --test --experimental-test-coverage"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.4.0",
    "eslint-plugin-de-morgan": "2.1.2",
    "eslint-plugin-hex-under": "1.9.2",
    "oxfmt": "0.50.0",
    "oxlint": "1.59.0",
    "terser": "5.47.1"
  },
  "engines": {
    "node": ">= 22.14.0",
    "npm": ">= 10.9.2"
  }
}
